# Epic Runner project configuration
# Copy to .epic-runner/config.toml and fill in values.
# Generated automatically by `epic-runner init`.

[api]
# Kapable API URL (default: https://api.kapable.dev)
# base_url = "https://api.kapable.dev"

# Admin API key — only needed for `init` (project creation)
# api_key = "sk_admin_..."

[project]
# Kapable project ID (set by `epic-runner init`)
# project_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Project-scoped data key (sk_live_*) — used for all CRUD operations
# Auto-generated by `epic-runner init` when creating a new project
# data_key = "sk_live_..."

# Ceremony flow ID override (optional — uses embedded default if omitted)
# ceremony_flow_id = "custom-flow-v1"
